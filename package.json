{
  "name": "reconix-frontend",
  "version": "1.0.0",
  "description": "Identity reconciliation platform for Nigeria",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "test:unit": "jest --testPathPattern=__tests__/unit",
    "test:component": "jest --testPathPattern=__tests__/component",
    "test:integration": "jest --testPathPattern=__tests__/integration",
    "type-check": "tsc --noEmit",
    "scss:check": "sass --no-source-map --stop-on-error --style=compressed $(find . -name '*.component.scss' -not -path './node_modules/*') /dev/null"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.3.0",
    "autoprefixer": "^10.4.16",
    "axios": "^1.6.0",
    "clsx": "^2.0.0",
    "date-fns": "^2.30.0",
    "lucide-react": "^0.294.0",
    "next": "^16.2.1",
    "postcss": "^8.4.31",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hook-form": "^7.48.0",
    "recharts": "^2.10.0",
    "sass": "^1.71.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.3.0",
    "zod": "^3.22.0",
    "zustand": "^4.4.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.1.0",
    "@testing-library/react": "^14.1.0",
    "@testing-library/user-event": "^14.5.0",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "eslint": "^8.54.0",
    "eslint-config-next": "^16.2.1",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.3.0",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.2"
  }
}
