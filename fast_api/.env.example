ENVIRONMENT=development
LOG_LEVEL=INFO
DEBUG=false

APP_MODULE=fast_api.main:app

DATABASE_URL=postgresql+asyncpg://reconix:CHANGE_ME@localhost:5432/reconix
DATABASE_DRIVER=postgresql
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=20
DATABASE_STATEMENT_TIMEOUT_MS=30000

JWT_SECRET_KEY=CHANGE_ME_TO_A_RANDOM_64_CHAR_STRING
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24
REFRESH_TOKEN_EXPIRATION_DAYS=7
PASSWORD_MIN_LENGTH=12
MAX_LOGIN_ATTEMPTS=5
ACCOUNT_LOCKOUT_MINUTES=15

CORS_ORIGINS=http://localhost:3000
ALLOWED_HOSTS=localhost,127.0.0.1

API_RATE_LIMIT_PER_MINUTE=100
AUTH_RATE_LIMIT_PER_MINUTE=5
MAX_REQUEST_SIZE_MB=10
MAX_BULK_UPLOAD_RECORDS=10000

PAGINATION_MAX_LIMIT=100
PAGINATION_DEFAULT_LIMIT=50

NIMC_API_URL=https://api.nimc.gov.ng
NIBSS_API_URL=https://api.nibss.gov.ng
BANK_API_TIMEOUT=30

SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
NOTIFICATION_FROM_EMAIL=no-reply@reconix.ng
ENABLE_EMAIL_NOTIFICATIONS=false

AUDIT_LOG_RETENTION_DAYS=365
ENFORCE_HTTPS=false
