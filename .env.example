NEXT_PUBLIC_API_BASE_URL=http://localhost:443/api/v1
NEXT_PUBLIC_APP_NAME=Reconix
NEXT_PUBLIC_APP_DESCRIPTION=National-scale identity reconciliation platform for Nigeria

# Backend settings (set in .env or environment)
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/reconix
# DATABASE_READ_REPLICA_URL=postgresql+asyncpg://user:password@replica:5432/reconix
# JWT_SECRET_KEY=<min-32-char-secret>
# FIELD_ENCRYPTION_KEY=<min-32-char-key-for-PII-encryption>
# ENVIRONMENT=development
# ENABLE_JSON_LOGGING=true
# ENABLE_METRICS=true
# ENABLE_IDEMPOTENCY=true
# ENABLE_TRACING=true
# ENABLE_WEBSOCKET=true

# Sentry (error tracking)
# SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
# SENTRY_RELEASE=1.0.0

# Redis (caching and token blacklist)
# REDIS_URL=redis://localhost:6379/0

# HashiCorp Vault (secret management)
# VAULT_URL=http://vault:8200
# VAULT_TOKEN=<vault-token>

# CDN (static asset delivery)
# NEXT_PUBLIC_CDN_URL=https://cdn.reconix.ng
